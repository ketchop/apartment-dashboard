<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>경제 캘린더 대시보드</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700&display=swap');

        body {
            font-family: 'Noto Sans KR', sans-serif;
            background-color: #f3f4f6; /* Tailwind gray-100 */
        }

        /* Importance Stars */
        .star-filled { color: #f59e0b; } /* Tailwind amber-500 */
        .star-empty { color: #d1d5db; } /* Tailwind gray-300 */

        /* Values color coding */
        .val-positive { color: #10b981; font-weight: 500;} /* Tailwind emerald-500 */
        .val-negative { color: #ef4444; font-weight: 500;} /* Tailwind red-500 */
        .val-neutral { color: #374151; } /* Tailwind gray-700 */

        /* Custom Scrollbar for table body */
        .table-container::-webkit-scrollbar {
            width: 8px;
        }
        .table-container::-webkit-scrollbar-track {
            background: #f1f1f1; 
            border-radius: 4px;
        }
        .table-container::-webkit-scrollbar-thumb {
            background: #cbd5e1; 
            border-radius: 4px;
        }
        .table-container::-webkit-scrollbar-thumb:hover {
            background: #94a3b8; 
        }

        /* Flag Icons */
        .flag-icon {
            width: 24px;
            height: 16px;
            display: inline-block;
            background-size: cover;
            background-position: center;
            border-radius: 2px;
            box-shadow: 0 1px 2px rgba(0,0,0,0.1);
        }
        
        .flag-us { background-image: url('https://flagcdn.com/w40/us.png'); }
        .flag-kr { background-image: url('https://flagcdn.com/w40/kr.png'); }
        .flag-eu { background-image: url('https://flagcdn.com/w40/eu.png'); }
        .flag-cn { background-image: url('https://flagcdn.com/w40/cn.png'); }
        .flag-jp { background-image: url('https://flagcdn.com/w40/jp.png'); }
        .flag-gb { background-image: url('https://flagcdn.com/w40/gb.png'); }

    </style>
</head>
<body class="text-gray-800 h-screen flex flex-col">

    <!-- Header -->
    <header class="bg-white shadow-sm z-10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex-shrink-0 flex items-center">
                    <i class="fa-solid fa-chart-line text-blue-600 text-2xl mr-2"></i>
                    <span class="font-bold text-xl tracking-tight">MacroTracker</span>
                </div>
                <div class="flex items-center space-x-4">
                    <div class="text-sm text-gray-500" id="current-time">
                        <!-- Time will be inserted here -->
                    </div>
                    <button class="bg-blue-50 hover:bg-blue-100 text-blue-600 px-3 py-1.5 rounded-md text-sm font-medium transition-colors">
                        <i class="fa-solid fa-bell mr-1"></i> 알림 설정
                    </button>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col overflow-hidden">
        
        <!-- Page Title & Controls -->
        <div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <h1 class="text-2xl font-bold text-gray-900">경제 캘린더</h1>
            
            <div class="flex flex-wrap gap-2">
                <!-- Date Filters -->
                <div class="inline-flex rounded-md shadow-sm" role="group">
                    <button type="button" class="filter-btn active px-4 py-2 text-sm font-medium text-blue-700 bg-blue-50 border border-blue-200 rounded-l-lg hover:bg-blue-100 focus:z-10 focus:ring-2 focus:ring-blue-300" data-filter="today">
                        오늘
                    </button>
                    <button type="button" class="filter-btn px-4 py-2 text-sm font-medium text-gray-900 bg-white border-t border-b border-r border-gray-200 hover:bg-gray-100 focus:z-10 focus:ring-2 focus:ring-blue-300" data-filter="tomorrow">
                        내일
                    </button>
                    <button type="button" class="filter-btn px-4 py-2 text-sm font-medium text-gray-900 bg-white border-t border-b border-r border-gray-200 rounded-r-lg hover:bg-gray-100 focus:z-10 focus:ring-2 focus:ring-blue-300" data-filter="thisWeek">
                        이번 주
                    </button>
                </div>

                <!-- Importance Filter -->
                <select id="importance-filter" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block px-3 py-2 shadow-sm">
                    <option value="all">모든 중요도</option>
                    <option value="3">⭐⭐⭐ (높음)</option>
                    <option value="2">⭐⭐ 이상 (중간)</option>
                </select>
            </div>
        </div>

        <!-- Summary Cards (Optional, adds dashboard feel) -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
            <div class="bg-white rounded-lg shadow-sm p-4 border border-gray-100">
                <div class="text-sm text-gray-500 mb-1">오늘의 주요 이벤트</div>
                <div class="text-2xl font-bold text-gray-800" id="high-impact-count">0</div>
            </div>
            <div class="bg-white rounded-lg shadow-sm p-4 border border-gray-100">
                <div class="text-sm text-gray-500 mb-1">VIX (변동성 지수)</div>
                <div class="flex items-center">
                    <span class="text-2xl font-bold text-gray-800 mr-2">14.25</span>
                    <span class="text-sm text-red-500 font-medium"><i class="fa-solid fa-caret-down"></i> -2.1%</span>
                </div>
            </div>
            <div class="bg-white rounded-lg shadow-sm p-4 border border-gray-100">
                <div class="text-sm text-gray-500 mb-1">M2 통화공급량 (미국)</div>
                <div class="flex items-center">
                    <span class="text-2xl font-bold text-gray-800 mr-2">20.8T</span>
                    <span class="text-sm text-emerald-500 font-medium"><i class="fa-solid fa-caret-up"></i> +0.1%</span>
                </div>
            </div>
        </div>

        <!-- Chart Section (Hidden by default) -->
        <div id="chart-section" class="hidden shrink-0 bg-white rounded-lg shadow-sm border border-gray-200 mb-6 p-4 transition-all duration-300">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 gap-4">
                <div>
                    <h2 id="chart-title" class="text-lg font-bold text-gray-800 flex items-center gap-2">
                        <span id="chart-event-name">이벤트 이름</span>
                        <span class="text-xs px-2 py-1 bg-gray-100 text-gray-600 rounded-md" id="chart-asset-name">관련 자산</span>
                    </h2>
                    <p class="text-sm text-gray-500 mt-1">해당 지표 발표 시점의 과거 시장 반응 (지수)</p>
                </div>
                <div class="inline-flex rounded-md shadow-sm shrink-0" role="group">
                    <button type="button" class="chart-tab-btn active px-4 py-1.5 text-sm font-medium text-blue-700 bg-blue-50 border border-blue-200 rounded-l-lg hover:bg-blue-100 focus:z-10 focus:ring-2 focus:ring-blue-300" data-years="5">5년치</button>
                    <button type="button" class="chart-tab-btn px-4 py-1.5 text-sm font-medium text-gray-900 bg-white border-t border-b border-r border-gray-200 hover:bg-gray-100 focus:z-10 focus:ring-2 focus:ring-blue-300" data-years="10">10년치</button>
                    <button type="button" class="chart-tab-btn px-4 py-1.5 text-sm font-medium text-gray-900 bg-white border-t border-b border-r border-gray-200 rounded-r-lg hover:bg-gray-100 focus:z-10 focus:ring-2 focus:ring-blue-300" data-years="15">15년치</button>
                </div>
            </div>
            <div class="relative h-56 w-full">
                <canvas id="marketReactionChart"></canvas>
            </div>
        </div>

        <!-- Calendar Table -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 flex-grow flex flex-col overflow-hidden">
            <!-- Table Header -->
            <div class="bg-gray-50 border-b border-gray-200 grid grid-cols-12 gap-2 p-4 text-xs font-semibold text-gray-500 uppercase tracking-wider sticky top-0">
                <div class="col-span-1 text-center">시간</div>
                <div class="col-span-1 text-center">통화</div>
                <div class="col-span-1 text-center">중요도</div>
                <div class="col-span-4">이벤트</div>
                <div class="col-span-2 text-center">시장 반응</div>
                <div class="col-span-1 text-right">실제</div>
                <div class="col-span-1 text-right">예측</div>
                <div class="col-span-1 text-right">이전</div>
            </div>

            <!-- Table Body (Scrollable) -->
            <div id="calendar-body" class="table-container overflow-y-auto flex-grow">
                <!-- Data rows will be injected here by JavaScript -->
                <div class="p-8 text-center text-gray-500" id="loading-state">
                    <i class="fa-solid fa-spinner fa-spin text-2xl mb-2 text-blue-500"></i>
                    <p>데이터를 불러오는 중입니다...</p>
                </div>
            </div>
        </div>

    </main>

    <script>
        // Mock Data Generation
        const generateMockData = () => {
            const today = new Date();
            const tomorrow = new Date(today);
            tomorrow.setDate(tomorrow.getDate() + 1);

            const formatDate = (date) => date.toISOString().split('T')[0];

            return [
                // Today's Data
                { id: 1, date: formatDate(today), time: "08:00", country: "KR", currency: "KRW", importance: 2, event: "한국 수출입물가지수 (전년 대비)", actual: "4.2%", forecast: "3.8%", previous: "3.5%", status: "better", marketAsset: "USD/KRW", marketChange: "-0.21%", marketTrend: "down" },
                { id: 2, date: formatDate(today), time: "09:30", country: "CN", currency: "CNY", importance: 3, event: "중국 소비자물가지수 (CPI) (전년 대비)", actual: "0.2%", forecast: "0.4%", previous: "-0.8%", status: "worse", marketAsset: "상해종합", marketChange: "-1.15%", marketTrend: "down" },
                { id: 3, date: formatDate(today), time: "16:00", country: "GB", currency: "GBP", importance: 2, event: "영국 실업률", actual: "3.9%", forecast: "3.8%", previous: "3.8%", status: "worse", marketAsset: "GBP/USD", marketChange: "-0.42%", marketTrend: "down" },
                { id: 4, date: formatDate(today), time: "19:00", country: "EU", currency: "EUR", importance: 3, event: "유로존 GDP (전분기 대비)", actual: null, forecast: "0.0%", previous: "-0.1%", status: "pending", marketAsset: "EUR/USD", marketChange: "+0.12%", marketTrend: "up" },
                { id: 5, date: formatDate(today), time: "21:30", country: "US", currency: "USD", importance: 3, event: "미국 근원 소비자물가지수 (CPI) (전월 대비)", actual: null, forecast: "0.3%", previous: "0.4%", status: "pending", marketAsset: "S&P 500", marketChange: "+0.45%", marketTrend: "up" },
                { id: 6, date: formatDate(today), time: "21:30", country: "US", currency: "USD", importance: 3, event: "미국 소비자물가지수 (CPI) (전년 대비)", actual: null, forecast: "3.1%", previous: "3.1%", status: "pending", marketAsset: "미 10년물 금리", marketChange: "-0.03%p", marketTrend: "down" },
                { id: 7, date: formatDate(today), time: "23:00", country: "US", currency: "USD", importance: 1, event: "미국 클리블랜드 연은 CPI", actual: null, forecast: "", previous: "0.3%", status: "pending", marketAsset: "달러 인덱스", marketChange: "-0.10%", marketTrend: "down" },
                
                // Tomorrow's Data
                { id: 8, date: formatDate(tomorrow), time: "08:50", country: "JP", currency: "JPY", importance: 2, event: "일본 핵심 기계류 수주 (전월 대비)", actual: null, forecast: "-1.0%", previous: "2.7%", status: "pending", marketAsset: "USD/JPY", marketChange: "+0.25%", marketTrend: "up" },
                { id: 9, date: formatDate(tomorrow), time: "16:00", country: "GB", currency: "GBP", importance: 3, event: "영국 국내총생산 (GDP) (전월 대비)", actual: null, forecast: "0.2%", previous: "-0.1%", status: "pending", marketAsset: "FTSE 100", marketChange: "+0.60%", marketTrend: "up" },
                { id: 10, date: formatDate(tomorrow), time: "19:00", country: "EU", currency: "EUR", importance: 2, event: "유로존 산업생산 (전월 대비)", actual: null, forecast: "-1.5%", previous: "2.6%", status: "pending", marketAsset: "Euro Stoxx 50", marketChange: "-0.30%", marketTrend: "down" },
                { id: 11, date: formatDate(tomorrow), time: "21:30", country: "US", currency: "USD", importance: 3, event: "미국 생산자물가지수 (PPI) (전월 대비)", actual: null, forecast: "0.3%", previous: "0.3%", status: "pending", marketAsset: "나스닥 100", marketChange: "+0.85%", marketTrend: "up" },
                { id: 12, date: formatDate(tomorrow), time: "21:30", country: "US", currency: "USD", importance: 3, event: "미국 소매판매 (전월 대비)", actual: null, forecast: "0.8%", previous: "-0.8%", status: "pending", marketAsset: "WTI 원유", marketChange: "+1.20%", marketTrend: "up" },
                { id: 13, date: formatDate(tomorrow), time: "23:30", country: "US", currency: "USD", importance: 2, event: "미국 원유재고", actual: null, forecast: "0.875M", previous: "1.367M", status: "pending", marketAsset: "WTI 원유", marketChange: "-0.50%", marketTrend: "down" }
            ];
        };

        const allData = generateMockData();
        let currentFilterDate = 'today';
        let currentFilterImportance = 'all';

        // Chart State
        let marketChartInstance = null;
        let currentSelectedEventId = null;
        let currentChartYears = 5;

        // Utility: Render Stars
        const renderStars = (count) => {
            let starsHtml = '';
            for (let i = 1; i <= 3; i++) {
                if (i <= count) {
                    starsHtml += '<i class="fa-solid fa-star text-xs mx-0.5 star-filled"></i>';
                } else {
                    starsHtml += '<i class="fa-solid fa-star text-xs mx-0.5 star-empty"></i>';
                }
            }
            return `<div class="flex justify-center" title="중요도: ${count}/3">${starsHtml}</div>`;
        };

        // Utility: Get Value Class
        const getValueClass = (status) => {
            if (status === 'better') return 'val-positive';
            if (status === 'worse') return 'val-negative';
            return 'val-neutral';
        };

        // Render Table Rows
        const renderTable = (data) => {
            const tbody = document.getElementById('calendar-body');
            tbody.innerHTML = '';

            if (data.length === 0) {
                tbody.innerHTML = `
                    <div class="p-8 text-center text-gray-500">
                        <i class="fa-regular fa-calendar-xmark text-3xl mb-3 text-gray-400"></i>
                        <p>해당 조건에 맞는 지표 발표가 없습니다.</p>
                    </div>`;
                return;
            }

            data.forEach((item, index) => {
                const rowClass = index % 2 === 0 ? 'bg-white' : 'bg-gray-50';
                const actualClass = getValueClass(item.status);
                
                // Highlight row if it's the next event (simple logic for demo)
                const isNextEvent = item.status === 'pending' && index === data.findIndex(d => d.status === 'pending');
                let borderLeft = isNextEvent ? 'border-l-4 border-blue-500' : 'border-l-4 border-transparent';

                const trendIcon = item.marketTrend === 'up' ? '<i class="fa-solid fa-caret-up"></i>' : (item.marketTrend === 'down' ? '<i class="fa-solid fa-caret-down"></i>' : '');
                const trendColor = item.marketTrend === 'up' ? 'text-emerald-500' : (item.marketTrend === 'down' ? 'text-red-500' : 'text-gray-500');

                // Selected state styling
                const isSelected = currentSelectedEventId === item.id;
                const rowBgClass = isSelected ? 'bg-blue-50' : rowClass;
                if(isSelected) borderLeft = 'border-l-4 border-blue-700';

                const row = `
                    <div onclick="handleRowClick(${item.id})" class="${rowBgClass} ${borderLeft} grid grid-cols-12 gap-2 p-3 items-center border-b border-gray-100 hover:bg-blue-100 transition-colors cursor-pointer">
                        <div class="col-span-1 text-center text-sm font-medium text-gray-700">${item.time}</div>
                        <div class="col-span-1 flex flex-col items-center justify-center">
                            <span class="flag-icon flag-${item.country.toLowerCase()} mb-1"></span>
                            <span class="text-xs text-gray-500 font-semibold">${item.currency}</span>
                        </div>
                        <div class="col-span-1">
                            ${renderStars(item.importance)}
                        </div>
                        <div class="col-span-4 text-sm font-medium text-gray-800 pr-2 truncate" title="${item.event}">
                            ${item.event}
                        </div>
                        <div class="col-span-2 flex flex-col justify-center items-center px-1 border-l border-r border-gray-200 bg-gray-100/50 rounded-md py-1 mx-1">
                            <span class="text-[10px] text-gray-500 font-medium leading-none mb-1">${item.marketAsset}</span>
                            <span class="text-xs font-bold ${trendColor}">${trendIcon} ${item.marketChange}</span>
                        </div>
                        <div class="col-span-1 text-right text-sm ${actualClass}">
                            ${item.actual !== null ? item.actual : '-'}
                        </div>
                        <div class="col-span-1 text-right text-sm text-gray-600">
                            ${item.forecast || '-'}
                        </div>
                        <div class="col-span-1 text-right text-sm text-gray-600">
                            ${item.previous || '-'}
                        </div>
                    </div>
                `;
                tbody.insertAdjacentHTML('beforeend', row);
            });
        };

        // Handle Row Click & Chart Logic
        const handleRowClick = (id, autoScroll = true) => {
            currentSelectedEventId = id;
            applyFilters(); // Re-render table to apply highlight

            const selectedEvent = allData.find(item => item.id === id);
            if (!selectedEvent) return;

            // Show chart section
            const chartSection = document.getElementById('chart-section');
            chartSection.classList.remove('hidden');

            // Update Text
            document.getElementById('chart-event-name').innerText = selectedEvent.event;
            document.getElementById('chart-asset-name').innerText = selectedEvent.marketAsset;

            renderChart(selectedEvent, currentChartYears);
            
            // Scroll to chart smoothly
            if (autoScroll) {
                chartSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
        };

        // Generate Mock Chart Data (Monthly)
        const generateChartData = (years, baseTrend) => {
            const dataPoints = years * 12; 
            const labels = [];
            const data = [];
            
            // Start with a mock base index (e.g., around 1000 ~ 3000)
            let currentIndex = 1500 + Math.random() * 500;
            
            let currentDate = new Date();
            for (let i = dataPoints; i >= 0; i--) {
                const d = new Date(currentDate);
                d.setMonth(d.getMonth() - i);
                labels.push(`${d.getFullYear()}.${String(d.getMonth()+1).padStart(2, '0')}`);
                
                // Generate random historical reaction data based on index values
                const volatility = 20; // 20 points variation
                const bias = baseTrend === 'up' ? 3 : -3;
                currentIndex += (Math.random() * volatility * 2) - volatility + bias;
                
                // Ensure index doesn't drop below 0 realistically
                if (currentIndex < 100) currentIndex = 100;

                data.push(parseFloat(currentIndex.toFixed(2)));
            }
            return { labels, data };
        };

        // Render Chart.js
        const renderChart = (eventItem, years) => {
            const ctx = document.getElementById('marketReactionChart').getContext('2d');
            
            // Destroy previous instance to avoid overlap
            if (marketChartInstance) {
                marketChartInstance.destroy();
            }

            const chartData = generateChartData(years, eventItem.marketTrend);
            const isPositiveTrend = eventItem.marketTrend === 'up';
            const lineColor = isPositiveTrend ? '#10b981' : '#ef4444'; // emerald or red
            const bgColor = isPositiveTrend ? 'rgba(16, 185, 129, 0.1)' : 'rgba(239, 68, 68, 0.1)';

            marketChartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: chartData.labels,
                    datasets: [{
                        label: `${eventItem.marketAsset} 지수`,
                        data: chartData.data,
                        borderColor: lineColor,
                        backgroundColor: bgColor,
                        borderWidth: 2,
                        pointRadius: 0,
                        pointHoverRadius: 4,
                        fill: true,
                        tension: 0.3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        intersect: false,
                        mode: 'index',
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.parsed.y !== null) {
                                        label += context.parsed.y.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
                                    }
                                    return label;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            ticks: { maxTicksLimit: years + 1 } // Roughly show years
                        },
                        y: {
                            grid: { color: '#f3f4f6' },
                            title: { display: true, text: '지수', font: {size: 11} }
                        }
                    }
                }
            });
        };

        // Filter Logic
        const applyFilters = () => {
            const todayStr = new Date().toISOString().split('T')[0];
            const tomorrowDate = new Date();
            tomorrowDate.setDate(tomorrowDate.getDate() + 1);
            const tomorrowStr = tomorrowDate.toISOString().split('T')[0];

            let filteredData = allData.filter(item => {
                // Date Filter
                let dateMatch = false;
                if (currentFilterDate === 'today') {
                    dateMatch = item.date === todayStr;
                } else if (currentFilterDate === 'tomorrow') {
                    dateMatch = item.date === tomorrowStr;
                } else {
                    dateMatch = true; // thisWeek (showing all mock data for demo)
                }

                // Importance Filter
                let importanceMatch = true;
                if (currentFilterImportance !== 'all') {
                    const minImportance = parseInt(currentFilterImportance);
                    if (minImportance === 3) {
                         importanceMatch = item.importance === 3;
                    } else if (minImportance === 2) {
                         importanceMatch = item.importance >= 2;
                    }
                }

                return dateMatch && importanceMatch;
            });

            renderTable(filteredData);
            updateDashboardCards(filteredData);
        };

        // Update Dashboard Summary Cards
        const updateDashboardCards = (data) => {
            // Count High Impact
            const highImpactCount = data.filter(item => item.importance === 3).length;
            document.getElementById('high-impact-count').innerText = highImpactCount;

            // Note: VIX and M2 are static in this mock layout.
            // In a real application, you would fetch these from an API
            // and update their respective DOM elements here.
        }

        // Find closest event to current time
        const findClosestEventId = () => {
            const now = new Date();
            let closestId = null;
            let minDiff = Infinity;

            allData.forEach(item => {
                const [year, month, day] = item.date.split('-');
                const [hour, minute] = item.time.split(':');
                const eventDate = new Date(year, month - 1, day, hour, minute);
                
                const diff = Math.abs(now - eventDate);
                if (diff < minDiff) {
                    minDiff = diff;
                    closestId = item.id;
                }
            });
            return closestId;
        };

        // Event Listeners
        document.addEventListener('DOMContentLoaded', () => {
            
            // Set current time
            const updateTime = () => {
                const now = new Date();
                const timeString = now.toLocaleTimeString('ko-KR', { hour: '2-digit', minute: '2-digit', second:'2-digit' });
                const dateString = now.toLocaleDateString('ko-KR', { month: 'long', day: 'numeric', weekday: 'short' });
                document.getElementById('current-time').innerText = `${dateString} ${timeString}`;
            };
            setInterval(updateTime, 1000);
            updateTime();

            // Simulate loading delay
            setTimeout(() => {
                applyFilters();
                
                // Select closest event by default without auto-scrolling
                const closestId = findClosestEventId();
                if (closestId) {
                    handleRowClick(closestId, false);
                }
            }, 500);

            // Filter Buttons (Date)
            const filterBtns = document.querySelectorAll('.filter-btn');
            filterBtns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    // Update Active Style
                    filterBtns.forEach(b => {
                        b.classList.remove('text-blue-700', 'bg-blue-50', 'active');
                        b.classList.add('text-gray-900', 'bg-white');
                    });
                    e.target.classList.remove('text-gray-900', 'bg-white');
                    e.target.classList.add('text-blue-700', 'bg-blue-50', 'active');

                    currentFilterDate = e.target.getAttribute('data-filter');
                    applyFilters();
                });
            });

            // Filter Select (Importance)
            document.getElementById('importance-filter').addEventListener('change', (e) => {
                currentFilterImportance = e.target.value;
                applyFilters();
            });

            // Chart Tabs (5y, 10y, 15y)
            const chartTabBtns = document.querySelectorAll('.chart-tab-btn');
            chartTabBtns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    // Update active styles
                    chartTabBtns.forEach(b => {
                        b.classList.remove('text-blue-700', 'bg-blue-50', 'active');
                        b.classList.add('text-gray-900', 'bg-white');
                    });
                    e.target.classList.remove('text-gray-900', 'bg-white');
                    e.target.classList.add('text-blue-700', 'bg-blue-50', 'active');

                    // Render chart with new timeline
                    currentChartYears = parseInt(e.target.getAttribute('data-years'));
                    if (currentSelectedEventId) {
                        const selectedEvent = allData.find(item => item.id === currentSelectedEventId);
                        renderChart(selectedEvent, currentChartYears);
                    }
                });
            });
        });

    </script>
</body>
